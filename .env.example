# API / Worker
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://mongo:27017/modeljudge
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_TTL=7d
CORS_ORIGIN=http://localhost:5173

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=modeljudge
MINIO_USE_SSL=false

ML_SERVICE_URL=http://ml-service:8000
ML_SERVICE_TOKEN=dev-ml-service-token-change-me

MAX_UPLOAD_BYTES=52428800
TRAIN_CONCURRENCY=2
EXPLAIN_CONCURRENCY=1

# Web (Vite)
VITE_API_URL=http://localhost:4000

# ML service
SERVICE_TOKEN=dev-ml-service-token-change-me
MINIO_ENDPOINT_ML=minio
MJS_VERSION=1.0.0
MAX_UPLOAD_ROWS=100000
MAX_FEATURES=512
